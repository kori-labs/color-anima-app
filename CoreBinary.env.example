# Template/example only. Do not treat these placeholder values as live intake
# metadata.
# The real CoreBinary.env is generated by the maintainer release process.
# Copying this file is not enough to fetch the core binary; the real
# CoreBinary.env is written by the release flow and contains checksums.
COLOR_ANIMA_KERNEL_VERSION=0.0.0
COLOR_ANIMA_KERNEL_REPOSITORY=kori-labs/color-anima-app
COLOR_ANIMA_KERNEL_RELEASE_TAG=kernel-v0.0.0
COLOR_ANIMA_KERNEL_ENCRYPTED_ASSET=ColorAnimaKernel.xcframework.zip.enc
COLOR_ANIMA_KERNEL_ZIP_SHA256=replace-with-plaintext-sha256
COLOR_ANIMA_KERNEL_ENCRYPTED_SHA256=replace-with-encrypted-sha256
COLOR_ANIMA_KERNEL_XCFRAMEWORK=ColorAnimaKernel.xcframework
